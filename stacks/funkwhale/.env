FUNKWHALE_VERSION=latest
FUNKWHALE_HOSTNAME=localhost
FUNKWHALE_PROTOCOL=http
FUNKWHALE_API_IP=0.0.0.0
FUNKWHALE_API_PORT=5000
DJANGO_SECRET_KEY=changeme_generate_a_long_random_string
DJANGO_ALLOWED_HOSTS=*
