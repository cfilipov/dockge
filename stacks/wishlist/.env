WISHLIST_PORT=3280
# If behind a reverse proxy, set this to your domain (e.g., https://wishlist.example.com)
ORIGIN=
# Hours until signup and password reset tokens expire
TOKEN_TIME=72
# Default currency when product search does not return one
DEFAULT_CURRENCY=USD
# Logging level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
# Maximum image upload size in bytes (default 5MB)
MAX_IMAGE_SIZE=5000000
